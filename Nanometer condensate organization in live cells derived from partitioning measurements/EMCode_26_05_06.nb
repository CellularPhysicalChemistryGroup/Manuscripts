           RowBox[{"BernsteinBasis", "[", 
            RowBox[{"splines", ",", "i", ",", 
             SuperscriptBox[
              RowBox[{"(", 
               FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}], ",", "x",
          ",", 
         RowBox[{"IncludeConstantBasis", "\[Rule]", "False"}], ",", 
         RowBox[{"Weights", "\[Rule]", 
          SuperscriptBox[
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{";;", "pnts"}], ",", "3"}], "]"}], "]"}], "2"]}], ",", 
         RowBox[{"VarianceEstimatorFunction", "\[Rule]", 
          RowBox[{"If", "[", 
           RowBox[{"varestimate1", ",", 
            RowBox[{"(", 
             RowBox[{"1", "&"}], ")"}], ",", "Automatic"}], "]"}]}]}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"coveq", "=", 
       RowBox[{
        RowBox[{"Quantile", "[", 
         RowBox[{
          RowBox[{"StudentTDistribution", "[", 
           RowBox[{
            RowBox[{"fit", "[", "\"\<ANOVATableDegreesOfFreedom\>\"", "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"-", "2"}], "]"}], "]"}], "]"}], ",", 
          RowBox[{"1", "-", "0.025"}]}], "]"}], "*", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{"FunctionExpand", "[", 
           RowBox[{"ExpandAll", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"BernsteinBasis", "[", 
                RowBox[{"splines", ",", "i", ",", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}], ".", 
             
             RowBox[{"fit", "[", "\"\<CovarianceMatrix\>\"", "]"}], ".", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"BernsteinBasis", "[", 
                RowBox[{"splines", ",", "i", ",", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}]}], 
            "]"}], "]"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"bandseq", "=", 
       RowBox[{
        RowBox[{"fit", "[", "x", "]"}], "+", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "0", ",", "1"}], "}"}], "*", 
         "coveq"}]}]}], ";", "\[IndentingNewLine]", "bandseq"}]}], 
    "]"}]}]}]}], "Input",
