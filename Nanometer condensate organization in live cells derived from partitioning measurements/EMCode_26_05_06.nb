        RowBox[{"\"\<yMajor\>\"", "->", "0.2"}], ",", 
        RowBox[{"\"\<yMinor\>\"", "->", "0.05"}]}], "]"}], "&"}], "/@", 
     RowBox[{"{", 
      RowBox[{"\"\<HeLa_v1\>\"", ",", "\"\<HeLa_v2\>\"", 
       ",", "\"\<HeLa_v3\>\"", ",", "\"\<HeLa_v4\>\"", 
       ",", "\"\<HeLa_v1_all\>\"", ",", "\"\<Jurkat\>\""}], "}"}]}], ",", 
    "2"}], "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Export", "[", 
