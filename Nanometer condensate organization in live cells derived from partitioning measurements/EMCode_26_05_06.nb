Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "calcCenters", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"calcCenters", "[", 
   RowBox[{"name_", ",", "xs_", ",", "ys_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"emData", "[", "name", "]"}]}], ",", 
       RowBox[{"frac", "=", "0.5"}], ",", "truemin", ",", "img", ",", 
       "minmax", ",", "binary", ",", "dilatedBinary", ",", "centers"}], "}"}],
      ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"truemin", "=", 
       RowBox[{"Min", "[", 
        RowBox[{"Blur", "[", 
         RowBox[{
          RowBox[{"Image", "[", 
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{
               RowBox[{"xs", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"xs", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"ys", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"ys", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "]"}], 
           RowBox[{"(*", "data", "*)"}], "]"}], ",", "5"}], "]"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"img", "=", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{
          RowBox[{"Reverse", "/@", 
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{
               RowBox[{"xs", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"xs", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"ys", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"ys", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "]"}]}], ",", 
          RowBox[{"ImageSize", "->", 
           RowBox[{"{", 
            RowBox[{"Automatic", ",", "256"}], "}"}]}]}], "]"}], "-", 
        "truemin"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"minmax", "=", 
       RowBox[{"(*", "MinMax", "*)"}], 
       RowBox[{"Quantile", "[", 
        RowBox[{"img", ",", 
         RowBox[{"{", 
          RowBox[{"0.005", ",", "0.995"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"binary", "=", 
       RowBox[{"Binarize", "[", 
        RowBox[{
         RowBox[{"Blur", "[", 
          RowBox[{"img", ",", "2"}], "]"}], ",", 
         RowBox[{
          RowBox[{"minmax", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{"frac", "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"minmax", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "-", 
             RowBox[{"minmax", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"dilatedBinary", "=", 
       RowBox[{"Dilation", "[", 
        RowBox[{"binary", ",", 
         RowBox[{"DiskMatrix", "[", "2", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"centers", "=", 
       RowBox[{"MaxDetect", "[", 
        RowBox[{"Blur", "[", 
         RowBox[{
          RowBox[{"DistanceTransform", "[", 
           RowBox[{"dilatedBinary", 
            RowBox[{"(*", "binary", "*)"}], ",", 
            RowBox[{"Padding", "->", "0"}]}], "]"}], ",", "2"}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", "centers"}]}], 
    "\[IndentingNewLine]", "]"}], "/;", 
   RowBox[{
    RowBox[{"ListQ", "[", 
     RowBox[{"emData", "[", "name", "]"}], "]"}], "&&", 
    RowBox[{"ListQ", "[", "xs", "]"}], "&&", 
    RowBox[{"ListQ", "[", "xs", "]"}], "&&", 
    RowBox[{
