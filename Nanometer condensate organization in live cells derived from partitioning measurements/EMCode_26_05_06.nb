Cell[BoxData[
 RowBox[{
  RowBox[{"Clear", "[", "smoothsearch", "]"}], ";", 
  RowBox[{
   RowBox[{"smoothsearch", "[", 
    RowBox[{"func_", ",", "start_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Delta]stop", "=", "0.01"}], ",", "eqcrossingone", ",", 
       "firstmin", ",", "eqcrossingtwo", ",", "BADQ", ",", "curr", ",", 
       "\[Delta]curr", ",", "globalmin"}], "}"}], ",", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"curr", "=", "start"}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Delta]curr", "=", "1."}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"\[Delta]curr", ">", "\[Delta]stop"}], ",", " ", 
        RowBox[{
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"func", "[", 
             RowBox[{"curr", "+", "\[Delta]curr"}], "]"}], ">", "1"}], ",", 
           RowBox[{"curr", "+=", "\[Delta]curr"}]}], "]"}], ";", 
         RowBox[{"\[Delta]curr", "=", 
          RowBox[{"\[Delta]curr", "/", "2"}]}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eqcrossingone", "=", 
       RowBox[{"curr", "+", 
        RowBox[{"\[Delta]stop", "/", "2"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Delta]curr", "=", "1."}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"\[Delta]curr", ">", "\[Delta]stop"}], ",", " ", 
        RowBox[{
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"func", "[", 
             RowBox[{"curr", "+", "\[Delta]curr"}], "]"}], "<", 
            RowBox[{"func", "[", "curr", "]"}]}], ",", 
           RowBox[{"curr", "+=", "\[Delta]curr"}]}], "]"}], ";", 
         RowBox[{"\[Delta]curr", "=", 
          RowBox[{"\[Delta]curr", "/", "2"}]}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"firstmin", "=", 
       RowBox[{"curr", "+", 
        RowBox[{"\[Delta]stop", "/", "2"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"globalmin", "=", 
       RowBox[{"func", "[", "curr", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"BADQ", "=", "False"}], ";", "\[IndentingNewLine]", 
      RowBox[{"\[Delta]curr", "=", "1."}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"\[Delta]curr", ">", "\[Delta]stop"}], ",", " ", 
        RowBox[{
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"func", "[", 
                RowBox[{"curr", "+", "\[Delta]curr"}], "]"}], "<", 
               "globalmin"}], ",", 
              RowBox[{
               RowBox[{"BADQ", "=", "True"}], ";", 
               RowBox[{"Break", "[", "]"}]}]}], "]"}], ";", 
            RowBox[{
             RowBox[{
              RowBox[{"func", "[", 
               RowBox[{"curr", "+", "\[Delta]curr"}], "]"}], "<", "1"}], "&&", 
             RowBox[{
              RowBox[{"func", "[", 
               RowBox[{"curr", "+", "\[Delta]curr"}], "]"}], ">", 
              RowBox[{"func", "[", "curr", "]"}]}]}]}], ",", 
           RowBox[{"curr", "+=", "\[Delta]curr"}]}], "]"}], ";", 
         RowBox[{"\[Delta]curr", "=", 
          RowBox[{"\[Delta]curr", "/", "2"}]}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eqcrossingtwo", "=", 
       RowBox[{"curr", "+", 
        RowBox[{"\[Delta]stop", "/", "2"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"BADQ", ",", 
        RowBox[{
        "Print", "[", "\"\<ERROR MIGHT NOT BE GLOBAL MIN\>\"", "]"}]}], "]"}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"eqcrossingone", ",", "firstmin", ",", "eqcrossingtwo"}], 
       "}"}]}]}], "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.982399888461752*^9, 3.9824000373286123`*^9}, {
  3.982400069488101*^9, 3.982400078694756*^9}, {3.9824003054104977`*^9, 
  3.982400377982347*^9}, {3.982400433094401*^9, 3.982400433242278*^9}, {
  3.982400700726522*^9, 3.98240073276584*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"8215d9fa-c12c-4328-9f26-32443fb779f2"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "getLocation", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"getLocation", "[", "name_", "]"}], ":=", 
  RowBox[{
   RowBox[{"getLocation", "[", "name", "]"}], "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tomin", ",", "eqcrossingone", ",", "firstmin", ",", "eqcrossingtwo", ",", 
       RowBox[{"f", "=", 
        RowBox[{
         RowBox[{"Around", "[", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", 
           FractionBox[
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "-", 
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], "2"]}], "]"}], "&"}]}]}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"tomin", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"XX", ",", 
               RowBox[{"#", "/.", 
                RowBox[{"{", 
                 RowBox[{"x", "->", "XX"}], "}"}]}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"XX", ",", "5", ",", "55", ",", "0.1"}], "}"}]}], "]"}],
            "&"}], "/@", 
          RowBox[{"getSpline", "[", "name", "]"}]}], ")"}]}], ";"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"eqcrossingone", "=", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SortBy", "[", 
             RowBox[{
              RowBox[{"Select", "[", 
               RowBox[{"#", ",", 
                RowBox[{
                 RowBox[{"5", "<", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "<", "25"}], "&"}]}], 
               "]"}], ",", 
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"#", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "-", "1"}], ")"}], "2"], 
               "&"}]}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}], "&"}], "/@", "tomin"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"firstmin", "=", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SortBy", "[", 
             RowBox[{
              RowBox[{"Select", "[", 
               RowBox[{"#", ",", 
                RowBox[{
                 RowBox[{"5", "<", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "<", "35"}], "&"}]}], 
               "]"}], ",", 
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "&"}]}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}], "&"}], "/@", "tomin"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"eqcrossingtwo", "=", 
        RowBox[{"f", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"SortBy", "[", 
             RowBox[{
              RowBox[{"Select", "[", 
               RowBox[{"#", ",", 
                RowBox[{
                 RowBox[{"25", "<", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "<", "50"}], "&"}]}], 
               "]"}], ",", 
              RowBox[{
               SuperscriptBox[
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"#", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "-", "1"}], ")"}], "2"], 
               "&"}]}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", "1"}], "]"}], "]"}], "&"}], "/@", "tomin"}], 
         "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"tomin", "=", 
       RowBox[{"Transpose", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"smoothsearch", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"getSpline", "[", "name", "]"}], "[", 
                RowBox[{"[", "i", "]"}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"x", "->", "#"}], "}"}]}], ")"}], "&"}], ",", "5"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"f", "/@", "tomin"}]}]}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"secmax", "=", 
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"SortBy", "[", 
            RowBox[{
             RowBox[{"Select", "[", 
              RowBox[{"#", ",", 
               RowBox[{
                RowBox[{"30", "<", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "<", "55"}], "&"}]}], "]"}],
              ",", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], "&"}]}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "1"}], "]"}], "]"}], "&"}], "/@", "tomin"}], 
        "]"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"{", 
      RowBox[{"eqcrossingone", ",", "firstmin", ",", "eqcrossingtwo"}], "}"}],
      "*)"}], "\[IndentingNewLine]", "]"}]}]}]}], "Input",
