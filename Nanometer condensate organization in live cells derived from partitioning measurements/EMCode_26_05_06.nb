Cell[CellGroupData[{

Cell["code direct from previous papers", "Subtitle",
 CellChangeTimes->{{3.982381662421933*^9, 
  3.98238166606437*^9}},ExpressionUUID->"a69510c3-6957-4ac9-959f-\
4e7ce8750386"],

Cell["\<\
Code direct from previous papers description:

Mathematica functions reproduced from Riback et al. Mol Cell 2023. These \
provide weighted spline curve fitting used consistently with that paper\
\[CloseCurlyQuote]s methodology for RDF smoothing and confidence band \
estimation.

Functions:
\[Bullet] getsplinecurve[data, pnts, splines] \[LongDash] fits a weighted \
Bernstein-basis spline (degree = splines) to the first pnts rows of data, \
using column 3 as squared weights; returns 200 evenly-spaced {x, fitted_y} \
pairs
\[Bullet] getsplinecurveerr[data, pnts, splines] \[LongDash] performs the \
same fit but additionally computes 95% confidence bands using the Student \
t-distribution and the fit\[CloseCurlyQuote]s covariance matrix; returns the \
upper and lower band as paired coordinate sequences
\[Bullet] LinearModelFit[] \[LongDash] Mathematica\[CloseCurlyQuote]s \
built-in weighted linear regression, used here with BernsteinBasis as the \
basis functions
\[Bullet] BernsteinBasis[n, i, x] \[LongDash] evaluates the i-th Bernstein \
polynomial of degree n at x \[LongDash] provides the flexible shape basis for \
the spline
\[Bullet] Quantile[StudentTDistribution[df], 0.975] \[LongDash] computes the \
t critical value for 95% confidence intervals given the residual degrees of \
freedom
\
\>", "Text",
 CellChangeTimes->{{3.942295492893352*^9, 3.942295501791837*^9}, {
  3.982381638195589*^9, 3.9823816503075123`*^9}, {3.987051846330779*^9, 
  3.987051856356275*^9}},ExpressionUUID->"02f33e02-96fc-4b83-a9ee-\
93f560da6234"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"varestimate1", "=", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"scallingtotry", "=", 
   FractionBox["18", "10"]}], 
  RowBox[{"(*", 
   FractionBox["18", "10"], "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "getsplinecurve", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"getsplinecurve", "[", 
   RowBox[{"data_", ",", 
    RowBox[{"pnts_", ":", "170"}], ",", 
    RowBox[{"splines_", ":", "20"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"end", "=", 
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{"pnts", ",", "1"}], "]"}], "]"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"#", "[", "x", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "end", ",", 
          FractionBox["end", "200"]}], "}"}]}], "]"}], "&"}], "@", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{";;", "pnts"}], ",", 
          RowBox[{";;", "2"}]}], "]"}], "]"}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"BernsteinBasis", "[", 
          RowBox[{"splines", ",", "i", ",", 
           SuperscriptBox[
            RowBox[{"(", 
             FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}], ",", "x", ",", 
       RowBox[{"IncludeConstantBasis", "\[Rule]", "False"}], ",", 
       RowBox[{"Weights", "\[Rule]", 
        SuperscriptBox[
         RowBox[{"data", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{";;", "pnts"}], ",", "3"}], "]"}], "]"}], "2"]}], ",", 
       RowBox[{"VarianceEstimatorFunction", "\[Rule]", 
        RowBox[{"If", "[", 
         RowBox[{"varestimate1", ",", 
          RowBox[{"(", 
           RowBox[{"1", "&"}], ")"}], ",", "Automatic"}], "]"}]}]}], 
      "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "getsplinecurveerr", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"getsplinecurveerr", "[", 
   RowBox[{"data_", ",", 
    RowBox[{"pnts_", ":", "170"}], ",", 
    RowBox[{"splines_", ":", "20"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"end", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"pnts", ",", "1"}], "]"}], "]"}]}], ",", "fit", ",", "coveq",
       ",", "bandseq"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"fit", "=", 
      RowBox[{"LinearModelFit", "[", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{";;", "pnts"}], ",", 
           RowBox[{";;", "2"}]}], "]"}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"BernsteinBasis", "[", 
           RowBox[{"splines", ",", "i", ",", 
            SuperscriptBox[
             RowBox[{"(", 
              FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], ",", 
          
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}], ",", "x", 
        ",", 
        RowBox[{"IncludeConstantBasis", "\[Rule]", "False"}], ",", 
        RowBox[{"Weights", "\[Rule]", 
         SuperscriptBox[
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{";;", "pnts"}], ",", "3"}], "]"}], "]"}], "2"]}], ",", 
        RowBox[{"VarianceEstimatorFunction", "\[Rule]", 
         RowBox[{"If", "[", 
          RowBox[{"varestimate1", ",", 
           RowBox[{"(", 
            RowBox[{"1", "&"}], ")"}], ",", "Automatic"}], "]"}]}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"coveq", "=", 
      RowBox[{
       RowBox[{"Quantile", "[", 
        RowBox[{
         RowBox[{"StudentTDistribution", "[", 
          RowBox[{
           RowBox[{"fit", "[", "\"\<ANOVATableDegreesOfFreedom\>\"", "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"-", "2"}], "]"}], "]"}], "]"}], ",", 
         RowBox[{"1", "-", "0.025"}]}], "]"}], "*", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"FunctionExpand", "[", 
          RowBox[{"ExpandAll", "[", 
           RowBox[{
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"BernsteinBasis", "[", 
               RowBox[{"splines", ",", "i", ",", 
                SuperscriptBox[
                 RowBox[{"(", 
                  FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}], ".", 
            RowBox[{"fit", "[", "\"\<CovarianceMatrix\>\"", "]"}], ".", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"BernsteinBasis", "[", 
               RowBox[{"splines", ",", "i", ",", 
                SuperscriptBox[
                 RowBox[{"(", 
                  FractionBox["x", "end"], ")"}], "scallingtotry"]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "0", ",", "splines"}], "}"}]}], "]"}]}], 
           "]"}], "]"}], "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"bandseq", "=", 
      RowBox[{
       RowBox[{"fit", "[", "x", "]"}], "+", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}], "*", "coveq"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Transpose", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"X", ",", "#"}], "}"}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{"bandseq", "/.", 
            RowBox[{"{", 
             RowBox[{"x", "\[Rule]", "X"}], "}"}]}], ")"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"X", ",", "0", ",", "end", ",", 
          FractionBox["end", "200"]}], "}"}]}], "]"}], "]"}]}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.942295512089158*^9, 3.942295542845715*^9}, {
   3.9422956987426*^9, 3.942295730821019*^9}, {3.942296089639174*^9, 
   3.942296097017189*^9}, {3.942296216549206*^9, 3.942296221994259*^9}, {
   3.942296257345231*^9, 3.942296261857249*^9}, {3.942296515869944*^9, 
   3.942296525756274*^9}, {3.942298427195607*^9, 3.9422984436674023`*^9}, {
   3.942299239974413*^9, 3.94229924921148*^9}, {3.942299990507289*^9, 
   3.942299994302679*^9}, {3.942300064087699*^9, 3.9423000722237988`*^9}, {
   3.9423001868721657`*^9, 3.942300187151972*^9}, {3.942300354429283*^9, 
   3.942300354552865*^9}, {3.942306438188155*^9, 3.9423064382541237`*^9}, 
