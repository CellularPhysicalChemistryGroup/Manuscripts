Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "getImg", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"getImg", "[", 
   RowBox[{"name_", ",", "xs_", ",", "ys_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"emData", "[", "name", "]"}]}], ",", "truemin", ",", "img", ",",
        "minmax"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"truemin", "=", 
       RowBox[{"Min", "[", 
        RowBox[{"Blur", "[", 
         RowBox[{
          RowBox[{"Image", "[", 
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{
               RowBox[{"xs", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"xs", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"ys", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"ys", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "]"}], 
           RowBox[{"(*", "data", "*)"}], "]"}], ",", "5"}], "]"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"img", "=", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{"Reverse", "/@", 
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{
              RowBox[{"xs", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ";;", 
              RowBox[{"xs", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"ys", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ";;", 
              RowBox[{"ys", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "]"}]}], "]"}], "-",
         "truemin"}]}], ";", "\[IndentingNewLine]", "img"}]}], "]"}], "/;", 
   RowBox[{
    RowBox[{"ListQ", "[", 
     RowBox[{"emData", "[", "name", "]"}], "]"}], "&&", 
    RowBox[{"ListQ", "[", "xs", "]"}], "&&", 
    RowBox[{"ListQ", "[", "xs", "]"}], "&&", 
    RowBox[{
     RowBox[{"Length", "[", "xs", "]"}], "==", "2"}], "&&", 
    RowBox[{
     RowBox[{"Length", "[", "xs", "]"}], "==", "2"}], "&&", 
    RowBox[{"NumberQ", "[", 
     RowBox[{
      RowBox[{"Total", "[", "xs", "]"}], "+", 
      RowBox[{"Total", "[", "ys", "]"}]}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"getImg", "[", "name_", "]"}], ":=", 
  RowBox[{"getImg", "[", 
   RowBox[{"name", ",", 
    RowBox[{"emXRange", "[", "name", "]"}], ",", 
    RowBox[{"emYRange", "[", "name", "]"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.982383570122857*^9, 3.9823836023180103`*^9}, {
