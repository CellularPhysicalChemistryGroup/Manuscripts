Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "fireImg", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fireImg", "[", 
   RowBox[{"name_", ",", "xs_", ",", "ys_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"emData", "[", "name", "]"}]}], ",", "truemin", ",", "img", ",",
        "minmax"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"truemin", "=", 
       RowBox[{"Min", "[", 
        RowBox[{"Blur", "[", 
         RowBox[{
          RowBox[{"Image", "[", "data", "]"}], ",", "5"}], "]"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"img", "=", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{
          RowBox[{"Reverse", "/@", 
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{
               RowBox[{"xs", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"xs", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"ys", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ";;", 
               RowBox[{"ys", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "]"}]}], ",", 
          RowBox[{"ImageSize", "->", 
           RowBox[{"{", 
            RowBox[{"Automatic", ",", "256"}], "}"}]}]}], "]"}], "-", 
        "truemin"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"minmax", "=", 
       RowBox[{"(*", "MinMax", "*)"}], 
       RowBox[{"Quantile", "[", 
        RowBox[{"img", ",", 
         RowBox[{"{", 
          RowBox[{"0.005", ",", "0.995"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"firemodeimage", "[", 
       FractionBox[
        RowBox[{"img", "-", 
         RowBox[{"minmax", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], 
        RowBox[{
         RowBox[{"minmax", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"minmax", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}]], "]"}]}]}], "\[IndentingNewLine]",
     "]"}], "/;", 
   RowBox[{
    RowBox[{"ListQ", "[", 
     RowBox[{"emData", "[", "name", "]"}], "]"}], "&&", 
    RowBox[{"ListQ", "[", "xs", "]"}], "&&", 
    RowBox[{"ListQ", "[", "xs", "]"}], "&&", 
    RowBox[{
     RowBox[{"Length", "[", "xs", "]"}], "==", "2"}], "&&", 
    RowBox[{
     RowBox[{"Length", "[", "xs", "]"}], "==", "2"}], "&&", 
    RowBox[{"NumberQ", "[", 
     RowBox[{
      RowBox[{"Total", "[", "xs", "]"}], "+", 
      RowBox[{"Total", "[", "ys", "]"}]}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fireImg", "[", "name_", "]"}], ":=", 
  RowBox[{"fireImg", "[", 
   RowBox[{"name", ",", 
    RowBox[{"emXRange", "[", "name", "]"}], ",", 
    RowBox[{"emYRange", "[", "name", "]"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9823819309426403`*^9, 3.982381980525505*^9}, {
