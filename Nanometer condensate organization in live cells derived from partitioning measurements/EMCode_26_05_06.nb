Cell[BoxData[
 RowBox[{
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"maxgrid", "=", "20"}], "}"}], ",", 
    RowBox[{"conv", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "3"}], "]"}], "]"}], ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"mind", "=", 
             RowBox[{
              RowBox[{"Min", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", 
                 RowBox[{";;", ",", 
                  RowBox[{";;", "2"}]}], "]"}], "]"}], "]"}], "-", "1"}]}], 
            "}"}], ",", 
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "-", "mind"}], ",", 
                 RowBox[{
                  RowBox[{"#", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "-", "mind"}]}], "}"}], "->",
                "1"}], "&"}], "/@", "#"}], "]"}]}], "]"}]}], "}"}], "&"}], "/@", 
      RowBox[{"Values", "[", 
       RowBox[{"GroupBy", "[", 
        RowBox[{
         RowBox[{"SortBy", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"i", ",", "j", ",", 
                 RowBox[{"4.", 
                  RowBox[{"Sqrt", "[", 
                   RowBox[{
                    SuperscriptBox["i", "2"], "+", 
                    SuperscriptBox["j", "2"]}], "]"}]}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", 
                 RowBox[{"-", "maxgrid"}], ",", "maxgrid", ",", "1"}], "}"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", 
                 RowBox[{"-", "maxgrid"}], ",", "maxgrid", ",", "1"}], 
                "}"}]}], "]"}], ",", "1"}], "]"}], ",", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", 
              RowBox[{"-", "1"}], "]"}], "]"}], "&"}]}], "]"}], ",", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"-", "1"}], "]"}], "]"}], "&"}]}], "]"}], "]"}]}]}]}], 
   "]"}], ";"}]], "Input",
